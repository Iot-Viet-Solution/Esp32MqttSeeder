# Enable MQTT5 protocol support
CONFIG_MQTT_PROTOCOL_5=y

# Use larger main task stack (publishers spawn their own tasks)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# Enable SNTP for NTP time sync
CONFIG_LWIP_DHCP_GET_NTP_SRV=y

# Increase FreeRTOS tick rate for finer timer resolution
CONFIG_FREERTOS_HZ=1000

# Set log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Partition table – single-app with larger OTA partition
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y
